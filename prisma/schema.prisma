generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── WORKSPACE (MULTI-TENANT) ─────────────────────────────────
model Workspace {
  id             String              @id @default(cuid())
  name           String
  slug           String              @unique
  logoUrl        String?
  primaryColor   String              @default("#18181b")
  plan           String              @default("starter") // free, starter, pro, agency
  planMaxClients Int                 @default(10)
  status         String              @default("active") // active, suspended, cancelled
  createdAt      DateTime            @default(now())
  users          User[]
  onboardingSessions OnboardingSession[]
}

// ─── AGENCY AUTH ─────────────────────────────────────────────
model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String
  passwordHash  String
  workspaceId   String?
  createdAt     DateTime       @default(now())
  workspace     Workspace?     @relation(fields: [workspaceId], references: [id])
  sessions      Session[]
  notifications Notification[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id])
}

// ─── TEAM ────────────────────────────────────────────────────
model TeamMember {
  id        String   @id @default(cuid())
  name      String
  role      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ─── CLIENTS ─────────────────────────────────────────────────
model Client {
  id             String    @id @default(cuid())
  name           String
  brandName      String?
  email          String?
  whatsapp       String?
  channels       String?
  industry       String
  country        String
  language       String    @default("es")
  phase          Int       @default(1)
  status         String    @default("active")
  onboardingDate DateTime  @default(now())
  archivedAt     DateTime?
  createdAt      DateTime  @default(now())

  profile            ClientProfile?
  emotionalCheckins  EmotionalCheckin[]
  itrScores          ItrScore[]
  funnelMetrics      FunnelMetric[]
  contentMetrics     ContentMetric[]
  ringActivations    RingActivation[]
  alerts             Alert[]
  onboardingSessions OnboardingSession[]
  blueprints         Blueprint[]
}

model ClientProfile {
  id                     String  @id @default(cuid())
  clientId               String  @unique

  // Soul
  purpose                String  @default("")
  values                 String  @default("")
  neverList              String  @default("")
  vision3Years           String  @default("")

  // ICP Basic
  icpDemographic         String  @default("")
  icpPain                String  @default("")
  icpDesire              String  @default("")
  icpObjection           String  @default("")

  // ICP Deep
  icpMicrosegment        String  @default("")
  icpInternalDialogue    String  @default("")
  icpDeepPain            String  @default("")
  icpDeepDesire          String  @default("")
  icpCounterargument     String  @default("")

  // Archetypes
  emotionalArchetype     String  @default("")
  emotionalArchetypeDesc String  @default("")
  audienceArchetype      String  @default("")
  audienceArchetypeDesc  String  @default("")
  archetypeRelationship  String  @default("")

  // Content
  contentEmotion         String  @default("")
  contentTransformation  String  @default("")
  contentPillars         String  @default("")
  voiceAdjectives        String  @default("")
  voiceVocabulary        String  @default("")
  voiceForbidden         String  @default("")
  toneByContext          String  @default("")
  channelFormats         String  @default("")

  // Funnel
  funnelType             Int     @default(0)
  funnelReason           String  @default("")
  pricingEntry           String  @default("")
  pricingCore            String  @default("")
  pricingPremium         String  @default("")
  valuePromise           String  @default("")

  // Philosophical Gate
  gateCanDeliver         Boolean @default(false)
  gateGenuinePurpose     Boolean @default(false)
  gateAutoServesPurpose  Boolean @default(false)
  gateMeasurableResults  Boolean @default(false)
  gateResult             String  @default("")
  gateDiagnosisNotes     String  @default("")
  initialEmotionalState  Int     @default(3)

  // Gitea
  giteaFolderCreated     Boolean @default(false)
  giteaFolderPath        String  @default("")

  client                 Client  @relation(fields: [clientId], references: [id])
}

// ─── CLIENT PERFORMANCE ──────────────────────────────────────
model EmotionalCheckin {
  id          String   @id @default(cuid())
  clientId    String
  level       Int
  notes       String   @default("")
  triggeredBy String   @default("manual")
  createdAt   DateTime @default(now())
  client      Client   @relation(fields: [clientId], references: [id])
}

model ItrScore {
  id          String   @id @default(cuid())
  clientId    String
  month       Int
  year        Int
  emotional   Int      @default(0)
  pedagogical Int      @default(0)
  strategic   Int      @default(0)
  narrative   Int      @default(0)
  technical   Int      @default(0)
  perceptive  Int      @default(0)
  total       Int      @default(0)
  scorePct    Float    @default(0)
  createdAt   DateTime @default(now())
  client      Client   @relation(fields: [clientId], references: [id])
}

model FunnelMetric {
  id          String   @id @default(cuid())
  clientId    String
  funnelType  Int
  clarity     Float    @default(0)
  coherence   Float    @default(0)
  leads       Int      @default(0)
  conversions Int      @default(0)
  revenue     Float    @default(0)
  measuredAt  DateTime @default(now())
  client      Client   @relation(fields: [clientId], references: [id])
}

model ContentMetric {
  id          String   @id @default(cuid())
  clientId    String
  channel     String
  format      String
  pillar      Int
  engagement  Float    @default(0)
  reach       Int      @default(0)
  publishedAt DateTime @default(now())
  client      Client   @relation(fields: [clientId], references: [id])
}

// ─── OPERATIONS ──────────────────────────────────────────────
model RingActivation {
  id          String    @id @default(cuid())
  clientId    String
  ringNumber  Int
  ringName    String
  phase       Int
  status      String    @default("pending")
  activatedAt DateTime?
  createdAt   DateTime  @default(now())
  client      Client    @relation(fields: [clientId], references: [id])
}

model CapacityLog {
  id             String   @id @default(cuid())
  date           DateTime @default(now())
  activeClients  Int
  teamSize       Int
  capacityPct    Float
  bottleneckRing Int?
  notes          String?
}

model Alert {
  id            String    @id @default(cuid())
  clientId      String
  type          String
  severity      String
  message       String
  triggeredAt   DateTime  @default(now())
  resolvedAt    DateTime?
  autoGenerated Boolean   @default(true)
  client        Client    @relation(fields: [clientId], references: [id])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  message   String
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])
}

// ─── AGENCY INTELLIGENCE ─────────────────────────────────────
model AgencyPattern {
  id               String   @id @default(cuid())
  period           String
  funnelType       Int
  industry         String
  avgItr           Float    @default(0)
  avgConversion    Float    @default(0)
  sampleSize       Int      @default(0)
  lastCalculatedAt DateTime @default(now())
}

model ContentIntelligence {
  id            String   @id @default(cuid())
  pillar        Int
  industry      String
  avgEngagement Float    @default(0)
  topFormat     String
  period        String
  createdAt     DateTime @default(now())
}

// ─── CLIENT AUTH ─────────────────────────────────────────────
model ClientUser {
  id           String            @id @default(cuid())
  email        String            @unique
  passwordHash String
  sessionId    String            @unique
  session      OnboardingSession @relation(fields: [sessionId], references: [id])
  sessions     ClientSession[]
  createdAt    DateTime          @default(now())
  mustResetPwd Boolean           @default(true)
}

model ClientSession {
  id        String     @id @default(cuid())
  token     String     @unique @default(cuid())
  clientId  String
  client    ClientUser @relation(fields: [clientId], references: [id])
  expiresAt DateTime
  createdAt DateTime   @default(now())
}

// ─── ONBOARDING PORTAL ───────────────────────────────────────
model OnboardingSession {
  id                   String    @id @default(cuid())
  clientId             String?
  clientName           String    @default("")
  brandName            String    @default("")
  email                String    @default("")
  whatsapp             String    @default("")
  language             String    @default("es")
  channels             String    @default("")
  industry             String    @default("")
  country              String    @default("")
  productDescription   String    @default("")
  productPrice         Float     @default(0)
  businessStage        String    @default("")
  monthlyRevenue       Float     @default(0)
  purpose              String    @default("")
  values               String    @default("")
  neverList            String    @default("")
  vision3Years         String    @default("")
  icpDemographic       String    @default("")
  icpPain              String    @default("")
  icpDesire            String    @default("")
  agencyContext        String    @default("")
  businessType         String    @default("")
  revenueModel         String    @default("")
  specificProduct      String    @default("")
  targetAudience       String    @default("")
  workspaceId          String?
  token                String    @unique @default(cuid())
  expiresAt            DateTime
  status               String    @default("pending")
  agencyReviewApproved Boolean   @default(false)
  completedAt          DateTime?
  ipAddress            String?
  createdAt            DateTime  @default(now())
  client               Client?   @relation(fields: [clientId], references: [id])
  workspace            Workspace? @relation(fields: [workspaceId], references: [id])
  questions            InterviewQuestion[]
  blueprints           Blueprint[]
  clientUser           ClientUser?
  assets               OnboardingAsset[]
  checklist            ChecklistItem[]
  proposals            Proposal[]
  invoices             Invoice[]
  approvalItems        ApprovalItem[]
  campaigns            Campaign[]
  contentPieces        ContentPiece[]
  marketIntelligence   MarketIntelligence?
}

model InterviewQuestion {
  id                String   @id @default(cuid())
  sessionId         String
  questionText      String
  category          String
  orderNum          Int
  whyAsking         String
  originalGenerated String
  session           OnboardingSession @relation(fields: [sessionId], references: [id])
  answers           InterviewAnswer[]
}

model InterviewAnswer {
  id          String   @id @default(cuid())
  questionId  String
  answerText  String
  autoSavedAt DateTime @default(now())
  question    InterviewQuestion @relation(fields: [questionId], references: [id])
}

model Blueprint {
  id               String    @id @default(cuid())
  clientId         String
  sessionId        String
  version          Int       @default(1)
  contentHtml      String
  contentMd        String
  agencyApprovedAt DateTime?
  deliveredAt      DateTime?
  createdAt        DateTime  @default(now())
  client           Client    @relation(fields: [clientId], references: [id])
  session          OnboardingSession @relation(fields: [sessionId], references: [id])
}

// ─── PHASE B: ONBOARDING CHECKLIST ───────────────────────────
model OnboardingAsset {
  id         String            @id @default(cuid())
  sessionId  String
  type       String            // logo, brand_guide, fonts, social_handles, photos, other
  label      String
  fileName   String
  filePath   String
  fileSize   Int
  mimeType   String            @default("")
  uploadedAt DateTime          @default(now())
  session    OnboardingSession @relation(fields: [sessionId], references: [id])
}

model ChecklistItem {
  id          String            @id @default(cuid())
  sessionId   String
  key         String            // logo_uploaded, brand_colors, social_handles, etc.
  label       String
  completed   Boolean           @default(false)
  completedAt DateTime?
  notes       String            @default("")
  session     OnboardingSession @relation(fields: [sessionId], references: [id])

  @@unique([sessionId, key])
}

// ─── PHASE B: PROPOSAL SYSTEM ────────────────────────────────
model Proposal {
  id             String            @id @default(cuid())
  sessionId      String
  version        Int               @default(1)
  status         String            @default("draft") // draft, sent, accepted, rejected, ghosted
  diagnosis      String            @default("")
  pricingEntry   Float             @default(0)
  pricingCore    Float             @default(0)
  pricingPremium Float             @default(0)
  selectedTier   String?           // entry, core, premium
  notes          String            @default("")
  sentAt         DateTime?
  respondedAt    DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  session        OnboardingSession @relation(fields: [sessionId], references: [id])
  invoices       Invoice[]
}

// ─── PHASE B: BILLING ────────────────────────────────────────
model Invoice {
  id          String    @id @default(cuid())
  proposalId  String?
  sessionId   String
  amount      Float
  currency    String    @default("USD")
  status      String    @default("pending") // pending, paid, overdue, cancelled
  paymentUrl  String?
  description String    @default("")
  dueDate     DateTime?
  paidAt      DateTime?
  createdAt   DateTime  @default(now())
  proposal    Proposal? @relation(fields: [proposalId], references: [id])
  session     OnboardingSession @relation(fields: [sessionId], references: [id])
}

// ─── PHASE D: INTELLIGENCE EXPANSION ─────────────────────────
model MarketIntelligence {
  id          String            @id @default(cuid())
  sessionId   String            @unique
  industry    String
  country     String
  competitors String            @default("") // JSON array
  trends      String            @default("") // JSON array
  positioning String            @default("")
  keywords    String            @default("") // JSON array
  rawSummary  String            @default("")
  generatedAt DateTime          @default(now())
  session     OnboardingSession @relation(fields: [sessionId], references: [id])
}

model AgencyLearning {
  id         String   @id @default(cuid())
  industry   String
  funnelType Int
  archetype  String
  insight    String
  sourceId   String   // sessionId of origin
  createdAt  DateTime @default(now())

  @@unique([sourceId, insight])
}

// ─── PHASE C: CONTENT & CAMPAIGN ENGINE ──────────────────────
model Campaign {
  id          String            @id @default(cuid())
  sessionId   String
  name        String
  objective   String            @default("")
  status      String            @default("draft") // draft, active, paused, completed
  channels    String            @default("") // comma-separated: instagram,tiktok,linkedin
  startDate   DateTime?
  endDate     DateTime?
  notes       String            @default("")
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  session     OnboardingSession @relation(fields: [sessionId], references: [id])
  pieces      ContentPiece[]
}

model ContentPiece {
  id          String    @id @default(cuid())
  sessionId   String
  campaignId  String?
  platform    String    // instagram, tiktok, facebook, linkedin, email, blog
  format      String    // post, reel, story, carousel, video, email, article
  hook        String    @default("")
  body        String    @default("")
  cta         String    @default("")
  hashtags    String    @default("")
  status      String    @default("draft") // draft, ready, scheduled, published
  scheduledAt DateTime?
  publishedAt DateTime?
  aiGenerated Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  session     OnboardingSession @relation(fields: [sessionId], references: [id])
  campaign    Campaign?         @relation(fields: [campaignId], references: [id])
}

// ─── PHASE B: HUMAN REVIEW QUEUE ─────────────────────────────
model ApprovalItem {
  id          String    @id @default(cuid())
  type        String    // strategy_review, proposal_sent, campaign_change, ethical_flag
  title       String
  description String    @default("")
  context     String    @default("") // JSON blob with relevant data
  status      String    @default("pending") // pending, approved, rejected, skipped
  priority    String    @default("normal") // normal, high, urgent
  sessionId   String?
  decidedBy   String?
  decisionNote String   @default("")
  decidedAt   DateTime?
  createdAt   DateTime  @default(now())
  session     OnboardingSession? @relation(fields: [sessionId], references: [id])
}
